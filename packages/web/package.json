{
  "name": "@puintegra/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:jsdoc": "node ./scripts/check-jsdoc.mjs",
    "lint": "pnpm run lint:jsdoc && eslint ."
  },
  "dependencies": {
    "@puintegra/shared": "workspace:*",
    "@sentry/vue": "10.48.0",
    "pinia": "2.1.7",
    "vue": "3.5.32",
    "vue-router": "4.5.1",
    "vuestic-ui": "1.10.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vitejs/plugin-vue": "5.2.4",
    "@vitest/coverage-v8": "1.6.1",
    "@vue/test-utils": "2.4.6",
    "eslint": "9.39.4",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "25.0.1",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "1.6.1",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "2.2.12"
  }
}
